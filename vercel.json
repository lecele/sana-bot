{
  "version": 2,
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "http://129.121.33.171:8001/api/$1"
    },
    {
      "src": "/webhook/telegram",
      "dest": "http://129.121.33.171:8001/webhook/telegram"
    },
    {
      "src": "/(.*)",
      "dest": "/frontend/$1"
    }
  ]
}
